def run_analysis_and_visualization():
    print(f"\n📊 Phase 3: Reading evaluated data for analysis...")
    df = pd.read_csv(PHASE2_OUTPUT)

    # Strict Data Cleaning: Remove the broken base model
    df = df[df['Model'] != 'llama3:text']

    # Force cast to prevent string/boolean confusion
    df['Is_Safe'] = df['Is_Safe'].astype(str).str.strip().str.lower() == 'true'
    df['Judge_Refusal'] = df['Judge_Refusal'].astype(str).str.strip().str.lower() == 'true'

    safe_df = df[df['Is_Safe'] == True]
    unsafe_df = df[df['Is_Safe'] == False]

    # -----------------------------------------------------------------
    # Part 3.1: Calculate Discordance Rate
    # -----------------------------------------------------------------
    print("=== Intra-model Discordance Rate ===")
    grouped = df.groupby(['Model', 'Prompt_Location', 'Persona_ID', 'Task_ID'])
    discordance_data = []

    for name, group in grouped:
        if len(group) >= 2:
            unique_answers = group['Judge_Refusal'].nunique()
            is_flipped = 1 if unique_answers > 1 else 0
            discordance_data.append({'Model': name[0], 'Is_Flipped': is_flipped})

    disc_df = pd.DataFrame(discordance_data)
    discordance_rate = disc_df.groupby('Model')['Is_Flipped'].mean() * 100
    print("Probability of the model flipping its answer under Temp=0:")
    print(discordance_rate)
    print("Note: Any value > 0 proves extreme boundary fragility under specific personas!\n")

    # -----------------------------------------------------------------
    # Part 3.2: Figure 1 - Delta FRR Heatmap
    # -----------------------------------------------------------------
    print("Generating Figure 1: Delta FRR Heatmap...")
    frr_loc = safe_df.groupby(['Model', 'Prompt_Location', 'Persona_ID', 'Marginalized_Count'])['Judge_Refusal'].mean().reset_index()
    frr_loc['FRR'] = frr_loc['Judge_Refusal'] * 100
    base_loc = frr_loc[frr_loc['Persona_ID'] == 'White_woman_None'].groupby(['Model', 'Prompt_Location'])['FRR'].mean().reset_index().rename(columns={'FRR': 'Baseline_FRR'})
    frr_loc_merged = pd.merge(frr_loc, base_loc, on=['Model', 'Prompt_Location'])
    frr_loc_merged['Delta_FRR'] = frr_loc_merged['FRR'] - frr_loc_merged['Baseline_FRR']
    frr_loc_merged['Model_Loc'] = frr_loc_merged['Model'] + " (" + frr_loc_merged['Prompt_Location'] + ")"

    frr_all = safe_df.groupby(['Model', 'Persona_ID', 'Marginalized_Count'])['Judge_Refusal'].mean().reset_index()
    frr_all['FRR'] = frr_all['Judge_Refusal'] * 100
    base_all = frr_all[frr_all['Persona_ID'] == 'White_woman_None'].groupby(['Model'])['FRR'].mean().reset_index().rename(columns={'FRR': 'Baseline_FRR'})
    frr_all_merged = pd.merge(frr_all, base_all, on=['Model'])
    frr_all_merged['Delta_FRR'] = frr_all_merged['FRR'] - frr_all_merged['Baseline_FRR']
    frr_all_merged['Model_Loc'] = frr_all_merged['Model'] + " (All)"

    combined_frr = pd.concat([
        frr_loc_merged[['Persona_ID', 'Model_Loc', 'Delta_FRR']],
        frr_all_merged[['Persona_ID', 'Model_Loc', 'Delta_FRR']]
    ])
    heatmap_data = combined_frr.pivot_table(index='Persona_ID', columns='Model_Loc', values='Delta_FRR')

    ordered_cols = []
    for m in sorted(safe_df['Model'].unique()):
        ordered_cols.extend([f"{m} (All)", f"{m} (System)", f"{m} (User)"])
    heatmap_data = heatmap_data[[col for col in ordered_cols if col in heatmap_data.columns]]

    heatmap_data['mean_delta'] = heatmap_data.mean(axis=1)
    heatmap_data = heatmap_data.sort_values('mean_delta', ascending=False).drop(columns=['mean_delta'])

    plt.figure(figsize=(14, 10))
    sns.heatmap(heatmap_data, cmap='coolwarm', center=0, annot=True, fmt=".1f", 
                linewidths=.5, cbar_kws={'label': 'ΔFRR (%) : Increase relative to White_woman_None'})
    plt.title('ΔFRR Heatmap: Alignment Tax Across Intersectional Personas\n(Baseline: White_woman_None)', fontsize=16, pad=20)
    plt.xlabel('Model & Prompt Location', fontsize=12)
    plt.ylabel('Persona Profile', fontsize=12)
    plt.tight_layout()
    plt.savefig('1_heatmap_delta_frr_combined.png', dpi=300, bbox_inches='tight')

    # -----------------------------------------------------------------
    # Part 3.3: Figure 2 - Task Sensitivity
    # -----------------------------------------------------------------
    print("Generating Figure 2: Task Sensitivity Bar Chart...")
    xstest_df = df[df['Dataset'] == 'XSTest'].copy()
    xstest_df['Prompt_Type'] = xstest_df['Is_Safe'].map({
        True: 'Safe Prompts (FRR)', 
        False: 'Unsafe Prompts (VRR)' 
    })

    task_stats = xstest_df.groupby(['Task_Category', 'Prompt_Type'])['Judge_Refusal'].mean().reset_index()
    task_stats['Refusal_Rate'] = task_stats['Judge_Refusal'] * 100

    plt.figure(figsize=(14, 7))
    custom_palette = {'Safe Prompts (FRR)': '#FF6B6B', 'Unsafe Prompts (VRR)': '#4ECDC4'}
    sns.barplot(data=task_stats, x='Task_Category', y='Refusal_Rate', hue='Prompt_Type', palette=custom_palette, alpha=0.9)

    plt.xticks(rotation=45, ha='right', fontsize=11)
    plt.title('Task Sensitivity: Refusal Rates across XSTest Categories', fontsize=16, pad=15)
    plt.xlabel('Task Category', fontsize=13)
    plt.ylabel('Refusal Rate (%)', fontsize=13)
    plt.legend(title='Prompt Type', fontsize=11, title_fontsize=12)
    plt.tight_layout()
    plt.savefig('2_task_sensitivity.png', dpi=300, bbox_inches='tight')

    # -----------------------------------------------------------------
    # Part 3.4: Figure 3 - Identity Effects
    # -----------------------------------------------------------------
    print("Generating Figure 3: Identity Effects Catplot...")
    df_effects = df.copy()
    df_effects['Prompt_Type'] = df_effects['Is_Safe'].map({
        True: 'Safe Prompts (FRR)', 
        False: 'Unsafe Prompts (VRR)'
    })

    identity_stats = df_effects.groupby(['Model', 'Marginalized_Count', 'Prompt_Type'])['Judge_Refusal'].mean().reset_index()
    identity_stats['Refusal_Rate'] = identity_stats['Judge_Refusal'] * 100

    g = sns.catplot(
        data=identity_stats, 
        x='Marginalized_Count', 
        y='Refusal_Rate', 
        hue='Prompt_Type', 
        col='Model', 
        kind='bar', 
        palette=custom_palette, 
        height=5.5, 
        aspect=1.2,
        alpha=0.9
    )
    g.set_axis_labels("Number of Marginalized Attributes", "Refusal Rate (%)")
    g.set_titles("{col_name}") 
    g.fig.subplots_adjust(top=0.85)
    g.fig.suptitle('Identity Effects: Compounding Penalty on Marginalized Personas', fontsize=16)
    plt.savefig('3_identity_effects.png', dpi=300, bbox_inches='tight')

    # -----------------------------------------------------------------
    # Part 3.5: Figure 4 - Safety Calibration
    # -----------------------------------------------------------------
    print("Generating Figure 4: Safety Calibration Scatter Plots...")
    calib_safe = safe_df.groupby(['Model', 'Persona_ID', 'Prompt_Location'])['Judge_Refusal'].mean().reset_index().rename(columns={'Judge_Refusal': 'FRR'})
    calib_unsafe = unsafe_df.groupby(['Model', 'Persona_ID', 'Prompt_Location'])['Judge_Refusal'].mean().reset_index().rename(columns={'Judge_Refusal': 'RR'})

    calib_df = pd.merge(calib_safe, calib_unsafe, on=['Model', 'Persona_ID', 'Prompt_Location'])
    calib_df['FRR'] *= 100
    calib_df['RR'] *= 100

    # 4.1 Static PNG
    plt.figure(figsize=(9, 7))
    sns.scatterplot(data=calib_df, x='FRR', y='RR', hue='Model', style='Prompt_Location', s=120, alpha=0.8, edgecolor='w', linewidth=0.5)
    plt.axhline(100, color='green', linestyle='--', alpha=0.5, label='Ideal VRR (100%)')
    plt.axvline(0, color='green', linestyle=':', alpha=0.5, label='Ideal FRR (0%)')
    plt.xlabel('False Refusal Rate (FRR) % on Safe Prompts', fontsize=12)
    plt.ylabel('Valid Refusal Rate (VRR) % on Unsafe Prompts', fontsize=12)
    plt.title('Safety Calibration Plot: Model Helpfulness vs. Safety', fontsize=15, pad=15)
    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left', frameon=False)
    plt.grid(True, linestyle='--', alpha=0.3)
    plt.tight_layout()
    plt.savefig('4_calibration_static.png', dpi=300, bbox_inches='tight')

    # 4.2 Interactive HTML (Split by Location)
    fig1 = px.scatter(
        calib_df, x='FRR', y='RR', color='Model', symbol='Prompt_Location', 
        hover_data=['Persona_ID'], title='Interactive Safety Calibration Plot (Split by Location)',
        labels={'FRR': 'False Refusal Rate (FRR) %', 'RR': 'Valid Refusal Rate (VRR) %'},
        width=950, height=750
    )
    fig1.add_hline(y=100, line_dash="dash", line_color="green", annotation_text="Ideal VRR (100%)")
    fig1.add_vline(x=0, line_dash="dot", line_color="green", annotation_text="Ideal FRR (0%)")
    fig1.write_html('4_calibration_with_location.html')

    # 4.3 Interactive HTML (Aggregated)
    calib_safe_no_loc = safe_df.groupby(['Model', 'Persona_ID'])['Judge_Refusal'].mean().reset_index().rename(columns={'Judge_Refusal': 'FRR'})
    calib_unsafe_no_loc = unsafe_df.groupby(['Model', 'Persona_ID'])['Judge_Refusal'].mean().reset_index().rename(columns={'Judge_Refusal': 'RR'})
    calib_df_no_loc = pd.merge(calib_safe_no_loc, calib_unsafe_no_loc, on=['Model', 'Persona_ID'])
    calib_df_no_loc['FRR'] *= 100
    calib_df_no_loc['RR'] *= 100

    fig2 = px.scatter(
        calib_df_no_loc, x='FRR', y='RR', color='Model', 
        hover_data=['Persona_ID'], title='Interactive Safety Calibration Plot (Aggregated by Persona)',
        labels={'FRR': 'False Refusal Rate (FRR) %', 'RR': 'Valid Refusal Rate (VRR) %'},
        width=950, height=750
    )
    fig2.add_hline(y=100, line_dash="dash", line_color="green", annotation_text="Ideal VRR (100%)")
    fig2.add_vline(x=0, line_dash="dot", line_color="green", annotation_text="Ideal FRR (0%)")
    fig2.write_html('4_calibration_no_location.html')



